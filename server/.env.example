# ============================================================
# server 环境变量示例（复制为 .env 并按需修改）
# ============================================================

# 监听端口
PORT=9091

# token 签名密钥 —— 上云前务必改成一长串随机字符串！
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=change-me-to-a-long-random-string

# 数据库文件路径（缺省为 ./data/housing.db）
# DB_PATH=/var/lib/housing/housing.db

# HTTPS 证书路径（缺省为 ./certs/key.pem 和 ./certs/cert.pem）
# 找到证书则启用 HTTPS，否则用 HTTP
# TLS_KEY=/etc/letsencrypt/live/yourdomain/privkey.pem
# TLS_CERT=/etc/letsencrypt/live/yourdomain/fullchain.pem
